# AoTTG2 Workshop frontend
# Values are base URLs (without /v1). Appends /v1 automatically.
# Local defaults
VITE_AUTH_API_BASE_URL=http://localhost:5010
VITE_WORKSHOP_API_BASE_URL=http://localhost:5011

# Override for non-local deployments (e.g. production) via env.
# Example:
# VITE_AUTH_API_BASE_URL=https://aottg2.com
# VITE_WORKSHOP_API_BASE_URL=https://workshop.aottg2.com
