# AoTTG2 Workshop frontend
# Values are base URLs (without /v1). Appends /v1 automatically.
# Local defaults
NEXT_PUBLIC_AUTH_API_BASE_URL=http://localhost:5010
NEXT_PUBLIC_AUTH_FRONTEND_BASE_URL=http://localhost:5173
NEXT_PUBLIC_WORKSHOP_API_BASE_URL=http://localhost:5011
NEXT_PUBLIC_SITE_URL=http://localhost:5173

# Local Workshop against prod accounts/website:
# NEXT_PUBLIC_AUTH_API_BASE_URL=https://aottg2.com
# NEXT_PUBLIC_AUTH_FRONTEND_BASE_URL=https://aottg2.com
# NEXT_PUBLIC_SITE_URL=http://localhost:5173

# Override for non-local deployments (e.g. production) via env.
# Example:
# NEXT_PUBLIC_AUTH_API_BASE_URL=https://aottg2.com
# NEXT_PUBLIC_AUTH_FRONTEND_BASE_URL=https://aottg2.com
# NEXT_PUBLIC_WORKSHOP_API_BASE_URL=https://workshop.aottg2.com
# NEXT_PUBLIC_SITE_URL=https://workshop.aottg2.com
